# ════════════════════════════════════════════════
#  ConnectBé — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ════════════════════════════════════════════════

# ── Base de données ───────────────────────────────
DB_ROOT_PASSWORD=change_me_root
DB_NAME=connectbe_kiosk
DB_USER=connectbe_user
DB_PASSWORD=change_me_db
DB_HOST=mysql
DB_PORT=3306

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Backend ───────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=change_me_jwt_secret_32chars

# ── APIs externes ─────────────────────────────────
OPENWEATHERMAP_API_KEY=       # https://openweathermap.org/api
FLIGHTAPI_KEY=                 # https://www.flightapi.io

# ── Localisation hôtel ────────────────────────────
HOTEL_NAME=ConnectBé
HOTEL_LAT=12.3641
HOTEL_LNG=-1.5332
HOTEL_CITY_OWM_ID=2355426     # ID OpenWeatherMap Ouagadougou
HOTEL_AIRPORT_IATA=OUA        # Code IATA aéroport Ouagadougou
HOTEL_PHONE=+22625000000
HOTEL_EMAIL=contact@connectbe.bf

# ── QR Code / PWA ─────────────────────────────────
KIOSK_PUBLIC_URL=http://localhost:3000

# ── Backoffice Admin ──────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=connectbe2026      # Changer en production !

# ── Kiosque ───────────────────────────────────────
IDLE_TIMEOUT_MS=60000         # Retour menu après Nms d'inactivité
